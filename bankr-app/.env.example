# Public RPC (optional; defaults to https://sepolia.base.org)
# VITE_RPC_URL=https://sepolia.base.org

# Required for production UI defaults (Railway: set before `npm run build`)
# VITE_MARKETPLACE_ADDRESS=0x...
# VITE_DEFAULT_RECEIPT_COLLECTION=0x...

# Documented only — app is hardcoded to Base Sepolia (84532). Other values are ignored (console warning).
# VITE_CHAIN_ID=84532

# NEVER put private keys, deployer secrets, or API keys that can move funds here.
# This frontend only uses the user's wallet to sign.
