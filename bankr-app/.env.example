# Required for production — public https://mainnet.base.org rate-limits eth_getLogs (receipt scan fails).
# VITE_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Required for production UI defaults (Railway: set before `npm run build`)
# VITE_MARKETPLACE_ADDRESS=0x...
# VITE_DEFAULT_RECEIPT_COLLECTION=0x02441aDdC542A3a3283c4468780eB876F9ADA8BA
# Do NOT use placeholder addresses like 0x1111…1111 — they cause failed scans.
# Optional — comma-separated extra fee-rights receipt contracts to scan (e.g. older deploy still holding user NFTs).
# VITE_RECEIPT_COLLECTION_ALIASES=0xb9E56dA4B83e77657296D7dE694754bd8b7d00db
# Must be the receipt contract your escrow mints (solidity: BankrFeeRightsReceipt — collection **Token Marketplace** / **TMPR**).
# does nothing unless escrow (and deploy scripts) are updated to mint that new receipt address; otherwise scans and links break.

# Documented only — app is hardcoded to Base mainnet (8453). Other values are ignored (console warning).
# VITE_CHAIN_ID=8453

# Optional — WalletConnect QR for mobile / other wallets (https://cloud.reown.com/) — then rebuild.
# VITE_WALLETCONNECT_PROJECT_ID=
# (alias) VITE_REOWN_PROJECT_ID=

# Optional — how many recent Base blocks to scan for ERC721 Transfer(to = you); max 500000. Lower if your RPC errors on getLogs.
# VITE_RECEIPT_SCAN_BLOCKS=80000

# Escrows (Token Marketplace bundle — see README DeployTokenMarketplace).
# VITE_ESCROW_ADDRESS=0x...              # BankrEscrowV3 (legacy name; still supported)
# VITE_BANKR_ESCROW_ADDRESS=0x...        # optional alias — same contract as Bankr escrow
# VITE_CLANKER_ESCROW_ADDRESS=0x...      # ClankerEscrowV1 — required for in-app Clanker listing
# VITE_CLANKER_DEFAULT_LOCKER=0x...      # optional — LpLockerv2 when listing without CLANKER_API_KEY (defaults to v3.1 deploy)
# VITE_DEFAULT_RECEIPT_COLLECTION=0x...  # shared TMPR receipt NFT contract

# NEVER put private keys, deployer secrets, or API keys that can move funds here.
# This frontend only uses the user's wallet to sign.

# ── Bankr proxy (Vercel serverless / compatible runner — not VITE_) ───────────
# api/bankr-launches.js — default (no template): creator fees for wallet (no key):
#   https://docs.bankr.bot/token-launching/reading-fees/
#   GET https://api.bankr.bot/public/doppler/creator-fees/{address}?days=30
#
# BANKR_CREATOR_FEES_DAYS=30   (optional, 1–90; only used with default template)
#
# Optional — recent launches only (50 max), server filters by feeRecipient/deployer:
# BANKR_LAUNCHES_API_TEMPLATE=https://api.bankr.bot/token-launches
#
# BANKR_API_KEY=   (optional — public read endpoints are unauthenticated per Bankr docs)
# BANKR_AUTH_HEADER=Authorization
# BANKR_AUTH_SCHEME=Bearer
#
# api/bankr-build-transfer.js — POST proxy for beneficiary transfer calldata (no key):
#   https://docs.bankr.bot/token-launching/transferring-fees/
#
# ── Clanker proxy (optional — multi-factory / richer token rows) ───────────────
# Public — creator search by wallet or Farcaster username (no key):
#   api/clanker-search-creator.js → https://clanker.world/api/search-creator
#   https://clanker.gitbook.io/documentation/public/get-tokens-by-creator
#
# Authenticated — full token row (locker_address, pool_address, pool_config.pairedToken, …).
# Without it: profile still lists Clanker tokens from public search; users paste the Uniswap V3 **pool** contract
# and **List** uses VITE_CLANKER_DEFAULT_LOCKER (or an optional pasted locker) to resolve the LP NFT on-chain.
#   api/clanker-get-token.js → https://www.clanker.world/api/get-clanker-by-address
#   https://clanker.gitbook.io/documentation/authenticated/get-token-by-address
# CLANKER_API_KEY=
#
# Optional overrides if Clanker changes hosts:
# CLANKER_SEARCH_CREATOR_URL=https://clanker.world/api/search-creator
# CLANKER_GET_TOKEN_URL=https://www.clanker.world/api/get-clanker-by-address
