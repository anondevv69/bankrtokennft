# ──────────────────────────────────────────────────────────────────
# LOCAL DEV / BASE SEPOLIA TESTNET
# Copy this to .env.local — it is gitignored.
# Run: npm run dev
# ──────────────────────────────────────────────────────────────────

# Switch to Base Sepolia (chainId 84532) for local / testnet testing.
# Remove this line (or set to 8453) to target Base mainnet.
VITE_CHAIN_ID=84532

# Public Base Sepolia RPC — use an Alchemy/Infura key to avoid rate-limits.
VITE_RPC_URL=https://sepolia.base.org
# Or with Alchemy:
# VITE_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── After running DeployGroupBuyTestnet.s.sol, paste the printed addresses below ──

# MockERC721 deployed by the testnet script
VITE_DEFAULT_RECEIPT_COLLECTION=

# GroupBuyEscrow deployed by the testnet script
VITE_GROUP_BUY_ESCROW_ADDRESS=

# Leave blank on testnet (no mainnet Bankr/Clanker escrows exist on Sepolia)
VITE_MARKETPLACE_ADDRESS=
VITE_BANKR_ESCROW_ADDRESS=
VITE_CLANKER_ESCROW_ADDRESS=
VITE_CLANKER_V4_ESCROW_ADDRESS=
VITE_RECEIPT_COLLECTION_ALIASES=
